{
  "name": "tipprunde",
  "version": "1.0.0-pre.8",
  "type": "module",
  "imports": {
    "#/*": "./src/*",
    "#db": "./db/index.ts",
    "#db/*": "./db/*"
  },
  "scripts": {
    "dev": "vp dev --port 3000",
    "build": "vp build",
    "preview": "vp preview",
    "lint": "vp lint",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "typecheck": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:push": "bun --env-file=.env run drizzle-kit push",
    "db:migrate": "bun --env-file=.env run drizzle-kit migrate",
    "db:migrate:prod": "bun --env-file=.env.production run drizzle-kit migrate",
    "db:studio": "bun --env-file=.env run drizzle-kit studio",
    "db:studio:prod": "bun --env-file=.env.production run drizzle-kit studio",
    "prepare": "vp config"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/react-start": "^1.167.50",
    "@tanstack/react-table": "^8.21.3",
    "@visx/axis": "^3.12.0",
    "@visx/event": "^3.12.0",
    "@visx/grid": "^3.12.0",
    "@visx/group": "^3.12.0",
    "@visx/responsive": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "@visx/tooltip": "^3.12.0",
    "drizzle-orm": "1.0.0-beta.22",
    "lucide-react": "^1.12.0",
    "motion": "^12.38.0",
    "nitro": "^3.0.260415-beta",
    "react": "^19.2.5",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-rsc": "^0.5.25",
    "drizzle-kit": "1.0.0-beta.22",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "bun@1.3.13"
}

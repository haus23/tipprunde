{
  "include": ["**/*.ts", "**/*.tsx", ".react-router/types/**/*"],
  "compilerOptions": {
    "skipLibCheck": true,
    "types": ["vite/client"],
    "isolatedModules": true,
    "jsx": "react-jsx",
    "module": "Preserve",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "rootDirs": [".", "./.react-router/types"]
  }
}

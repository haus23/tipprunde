{
  "name": "@tipprunde/db",
  "private": true,
  "type": "module",
  "exports": {
    "./schema": "./src/schema.ts",
    "./relations": "./src/relations.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:push": "dotenv -e .env.dev -- drizzle-kit push",
    "db:migrate:staging": "dotenv -e .env.staging -- drizzle-kit migrate",
    "db:migrate:prod": "dotenv -e .env.prod -- drizzle-kit migrate",
    "db:studio:dev": "dotenv -e .env.dev -- drizzle-kit studio",
    "db:studio:prod": "dotenv -e .env.prod -- drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "catalog:orm"
  },
  "devDependencies": {
    "@libsql/client": "catalog:orm",
    "@types/node": "catalog:types",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "catalog:orm"
  }
}

{
  "include": [
    "app/**/*",
    "app/**/.server/**/*",
    "app/**/.client/**/*",
    ".react-router/types/**/*"
  ],
  "compilerOptions": {
    // Type checking
    "strict": true,

    // Additional typings / libs
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],

    // Constraints
    "verbatimModuleSyntax": true,

    // React Router
    "jsx": "react-jsx",

    // Modules
    "module": "Preserve",
    "moduleDetection": "force",

    // Bundler
    "noEmit": true,
    "skipLibCheck": true,

    // DX
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "#/*": ["./app/*"]
    }
  }
}

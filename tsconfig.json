{
  "include": ["app/**/*"],
  "compilerOptions": {
    // Type checking
    "strict": true,

    // Additional typings
    "types": ["vite/client"],

    // Constraints
    "verbatimModuleSyntax": true,

    // React Router
    "jsx": "react-jsx",

    // Modules
    "module": "Preserve",
    "moduleDetection": "force",

    // Bundler
    "noEmit": true,
    "skipLibCheck": true,

    // DX
    "paths": {
      "#/*": ["./app/*"]
    }
  }
}

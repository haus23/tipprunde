{
  "compilerOptions": {
    // App
    "jsx": "react-jsx",
    "target": "ES2024",
    "types": ["vite/client"],

    // Strictness
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    // Typechecking
    "noEmit": true,
    "skipLibCheck": true,

    // Bundler
    "module": "Preserve",
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true
  }
}

{
  "include": ["**/*.ts", "**/*.tsx", "**/.server/**/*.ts"],
  "compilerOptions": {
    // Enable modern JS
    "target": "ES2024",
    // Enable strict mode
    "strict": true,
    // Bundler Mode (Vite)
    "module": "Preserve",
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "types": ["vite/client"],
    // React
    "jsx": "react-jsx",
    // React Router
    "rootDirs": [".", "./.react-router/types"],
    // DX
    "paths": {
      "~/*": ["./app/*"]
    }
  }
}
